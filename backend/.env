NODE_ENV=development
PORT=5000
API_BASE=/api/v1

# XAMPP MySQL (default: user root, no password)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sanpy_tourism

# JWT
JWT_SECRET=sanpy-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Admin seed (used by scripts/seed-admin.js)
ADMIN_EMAIL=admin@sanpy.local
ADMIN_PASSWORD=Admin@123
