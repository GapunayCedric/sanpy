NODE_ENV=development
PORT=8080
API_BASE=/api/v1

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sanpy_tourism

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Uploads (relative to backend root)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
ALLOWED_MIME_PDF=application/pdf
ALLOWED_MIME_IMAGE=image/jpeg,image/png,image/webp

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
